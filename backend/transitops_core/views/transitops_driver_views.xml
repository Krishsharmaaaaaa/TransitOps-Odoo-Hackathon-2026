<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_transitops_driver_tree" model="ir.ui.view">
        <field name="name">transitops.driver.tree</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <tree string="Drivers" decoration-success="availability == 'available'" decoration-warning="availability in ('assigned', 'on_duty')" decoration-danger="status in ('inactive', 'suspended')">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="license_number"/>
                <field name="license_expiry"/>
                <field name="experience"/>
                <field name="assigned_vehicle_id"/>
                <field name="availability"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_transitops_driver_form" model="ir.ui.view">
        <field name="name">transitops.driver.form</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Driver Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="license_number"/>
                            <field name="license_expiry"/>
                        </group>
                        <group>
                            <field name="experience"/>
                            <field name="assigned_vehicle_id"/>
                            <field name="availability"/>
                            <field name="status"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="address"/>
                        <field name="emergency_contact"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_transitops_driver_kanban" model="ir.ui.view">
        <field name="name">transitops.driver.kanban</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="license_number"/>
                <field name="license_expiry"/>
                <field name="assigned_vehicle_id"/>
                <field name="availability"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="employee_id"/></div>
                                <div><field name="phone"/></div>
                                <div><field name="assigned_vehicle_id"/></div>
                                <div><field name="availability"/> · <field name="status"/></div>
                                <div><field name="license_expiry"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_transitops_driver_search" model="ir.ui.view">
        <field name="name">transitops.driver.search</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="license_number"/>
                <field name="assigned_vehicle_id"/>
                <field name="availability"/>
                <field name="status"/>
                <filter string="Available" name="available" domain="[('availability', '=', 'available')]"/>
                <filter string="Assigned" name="assigned" domain="[('availability', '=', 'assigned')]"/>
                <filter string="On Duty" name="on_duty" domain="[('availability', '=', 'on_duty')]"/>
                <filter string="Active" name="active" domain="[('status', '=', 'active')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Availability" name="group_availability" context="{'group_by': 'availability'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transitops_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transitops.driver</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_transitops_driver_search"/>
    </record>
</odoo>