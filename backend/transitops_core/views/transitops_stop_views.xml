<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_transitops_stop_tree" model="ir.ui.view">
        <field name="name">transitops.stop.tree</field>
        <field name="model">transitops.stop</field>
        <field name="arch" type="xml">
            <tree string="Stops" decoration-success="status == 'active'" decoration-warning="status == 'draft'" decoration-danger="status in ('inactive', 'completed')">
                <field name="stop_id"/>
                <field name="stop_name"/>
                <field name="route_id"/>
                <field name="stop_sequence"/>
                <field name="landmark"/>
                <field name="status"/>
                <field name="expected_arrival_time"/>
                <field name="expected_departure_time"/>
            </tree>
        </field>
    </record>

    <record id="view_transitops_stop_form" model="ir.ui.view">
        <field name="name">transitops.stop.form</field>
        <field name="model">transitops.stop</field>
        <field name="arch" type="xml">
            <form string="Stop">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="stop_name" placeholder="Stop Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="stop_id"/>
                            <field name="route_id"/>
                            <field name="stop_sequence"/>
                            <field name="status"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="landmark"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="expected_arrival_time"/>
                        </group>
                        <group>
                            <field name="expected_departure_time"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Operational notes, access instructions, or exceptions..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_transitops_stop_kanban" model="ir.ui.view">
        <field name="name">transitops.stop.kanban</field>
        <field name="model">transitops.stop</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="stop_id"/>
                <field name="stop_name"/>
                <field name="route_id"/>
                <field name="stop_sequence"/>
                <field name="landmark"/>
                <field name="status"/>
                <field name="expected_arrival_time"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_details">
                                <strong><field name="stop_name"/></strong>
                                <div><field name="stop_id"/></div>
                                <div><field name="route_id"/></div>
                                <div>Sequence: <field name="stop_sequence"/></div>
                                <div><field name="landmark"/></div>
                                <div><field name="status"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_transitops_stop_search" model="ir.ui.view">
        <field name="name">transitops.stop.search</field>
        <field name="model">transitops.stop</field>
        <field name="arch" type="xml">
            <search string="Search Stops">
                <field name="stop_id"/>
                <field name="stop_name"/>
                <field name="route_id"/>
                <field name="status"/>
                <field name="landmark"/>
                <field name="stop_sequence"/>
                <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('status', '=', 'active')]"/>
                <filter string="Inactive" name="inactive" domain="[('status', '=', 'inactive')]"/>
                <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Route" name="group_route" context="{'group_by': 'route_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transitops_stop" model="ir.actions.act_window">
        <field name="name">Stops</field>
        <field name="res_model">transitops.stop</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_transitops_stop_search"/>
    </record>
</odoo>