<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_transitops" model="ir.module.category">
        <field name="name">TransitOps</field>
        <field name="description">TransitOps role management</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_transitops_dispatcher" model="res.groups">
        <field name="name">Dispatcher</field>
        <field name="category_id" ref="module_category_transitops"/>
    </record>

    <record id="group_transitops_fleet_manager" model="res.groups">
        <field name="name">Fleet Manager</field>
        <field name="category_id" ref="module_category_transitops"/>
    </record>

    <record id="group_transitops_maintenance_manager" model="res.groups">
        <field name="name">Maintenance Manager</field>
        <field name="category_id" ref="module_category_transitops"/>
    </record>

    <record id="group_transitops_driver" model="res.groups">
        <field name="name">Driver</field>
        <field name="category_id" ref="module_category_transitops"/>
    </record>

    <record id="group_transitops_passenger" model="res.groups">
        <field name="name">Passenger (Future Ready)</field>
        <field name="category_id" ref="module_category_transitops"/>
    </record>

    <record id="group_transitops_transport_manager" model="res.groups">
        <field name="name">Transport Manager</field>
        <field name="category_id" ref="module_category_transitops"/>
        <field name="implied_ids" eval="[(6, 0, [ref('group_transitops_dispatcher'), ref('group_transitops_fleet_manager'), ref('group_transitops_maintenance_manager')])]"/>
    </record>

    <record id="group_transitops_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_transitops"/>
        <field name="implied_ids" eval="[(6, 0, [ref('group_transitops_transport_manager'), ref('group_transitops_dispatcher'), ref('group_transitops_fleet_manager'), ref('group_transitops_maintenance_manager'), ref('group_transitops_driver')])]"/>
    </record>

    <record id="rule_transitops_driver_own_profile" model="ir.rule">
        <field name="name">Driver: own profile only</field>
        <field name="model_id" ref="model_transitops_driver"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_transitops_driver'))]"/>
    </record>

    <record id="rule_transitops_driver_own_trips" model="ir.rule">
        <field name="name">Driver: own trips only</field>
        <field name="model_id" ref="model_transitops_trip"/>
        <field name="domain_force">[('assigned_driver_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_transitops_driver'))]"/>
    </record>

    <record id="rule_transitops_driver_own_incidents" model="ir.rule">
        <field name="name">Driver: own incidents only</field>
        <field name="model_id" ref="model_transitops_incident"/>
        <field name="domain_force">['|', ('reporter_id', '=', user.id), ('driver_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_transitops_driver'))]"/>
    </record>

    <record id="rule_transitops_driver_own_notifications" model="ir.rule">
        <field name="name">Driver: own notifications only</field>
        <field name="model_id" ref="model_transitops_notification"/>
        <field name="domain_force">[('recipient_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_transitops_driver'))]"/>
    </record>
</odoo>